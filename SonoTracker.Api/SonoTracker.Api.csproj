<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
    <DocumentationFile>SonoTracker.Api.xml</DocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Controllers\V2\Lookups\**" />
    <Content Remove="Controllers\V2\Lookups\**" />
    <EmbeddedResource Remove="Controllers\V2\Lookups\**" />
    <None Remove="Controllers\V2\Lookups\**" />
  </ItemGroup>



  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="NetCore.AutoRegisterDi" Version="2.2.1" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="7.2.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SonoTracker.Infrastructure\SonoTracker.Infrastructure.csproj" />
    <ProjectReference Include="..\SonoTracker.Application\SonoTracker.Application.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Controllers\V2\Business\" />
    <Folder Include="wwwroot\OrgRequirements\" />
  </ItemGroup>

</Project>
